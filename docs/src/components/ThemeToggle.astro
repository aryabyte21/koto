---
---

<starlight-theme-toggle>
  <div class="theme-pill">
    <button type="button" data-set-theme="light" aria-label="Light theme" aria-pressed="false">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
    </button>
    <button type="button" data-set-theme="dark" aria-label="Dark theme" aria-pressed="false">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>
    <button type="button" data-set-theme="auto" aria-label="System theme" aria-pressed="false">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
    </button>
  </div>
</starlight-theme-toggle>

<script>
class StarlightThemeToggle extends HTMLElement {
  connectedCallback() {
    const buttons = this.querySelectorAll<HTMLButtonElement>('button[data-set-theme]');

    const sync = () => {
      const stored = typeof localStorage !== 'undefined'
        ? localStorage.getItem('starlight-theme') || 'auto'
        : 'auto';
      buttons.forEach((btn) => {
        const active = btn.dataset.setTheme === stored;
        btn.classList.toggle('active', active);
        btn.setAttribute('aria-pressed', String(active));
      });
    };

    const applyTheme = (pref: string) => {
      if (pref === 'auto') {
        const prefersDark = matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.dataset.theme = prefersDark ? 'dark' : 'light';
      } else {
        document.documentElement.dataset.theme = pref;
      }
    };

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const value = btn.dataset.setTheme!;
        localStorage.setItem('starlight-theme', value);
        applyTheme(value);
        sync();
      });
    });

    matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
      const stored = localStorage.getItem('starlight-theme') || 'auto';
      if (stored === 'auto') applyTheme('auto');
    });

    sync();

    new MutationObserver(sync).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });
  }
}
customElements.define('starlight-theme-toggle', StarlightThemeToggle);
</script>

<style>
  .theme-pill {
    display: inline-flex;
    align-items: center;
    background: var(--koto-surface);
    border: 1px solid var(--koto-border);
    border-radius: 999px;
    padding: 3px;
    gap: 2px;
  }

  .theme-pill button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 999px;
    border: none;
    background: transparent;
    color: var(--sl-color-gray-3);
    cursor: pointer;
    transition: all 150ms ease;
    padding: 0;
  }

  .theme-pill button:hover {
    color: var(--sl-color-text);
  }

  .theme-pill button.active {
    background: var(--sl-color-accent);
    color: white;
  }

  :root[data-theme="light"] .theme-pill button.active {
    color: white;
  }
</style>
