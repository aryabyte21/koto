---
/**
 * SVG rendering of the koto ASCII logo.
 * Box-drawing characters don't render well in web fonts,
 * so we bake them into an SVG with a known monospace font.
 */
---

<svg class="ascii-logo-svg" viewBox="0 0 320 55" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="koto">
  <text
    x="160"
    y="18"
    text-anchor="middle"
    font-family="'Courier New', Courier, monospace"
    font-size="16"
    font-weight="bold"
    fill="currentColor"
  >╦╔═  ╔═╗  ╔╦╗  ╔═╗</text>
  <text
    x="160"
    y="35"
    text-anchor="middle"
    font-family="'Courier New', Courier, monospace"
    font-size="16"
    font-weight="bold"
    fill="currentColor"
  >╠╩╗  ║ ║   ║   ║ ║</text>
  <text
    x="160"
    y="52"
    text-anchor="middle"
    font-family="'Courier New', Courier, monospace"
    font-size="16"
    font-weight="bold"
    fill="currentColor"
  >╩ ╩  ╚═╝   ╩   ╚═╝</text>
</svg>

<style>
  .ascii-logo-svg {
    display: block;
    margin: 0 auto 1.5rem;
    width: 280px;
    height: auto;
    color: var(--sl-color-accent);
  }
</style>
